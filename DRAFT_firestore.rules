import React, { useState, useEffect, useMemo } from 'react';
import { motion } from 'motion/react';
import { Loader2, BrainCircuit, TrendingUp, TrendingDown, Minus, ChevronLeft, ArrowLeft } from 'lucide-react';
import { Invoice } from '../lib/productService';
import { AIPriceAnalysisResult, ProcessedProduct, PriceChangeRecord } from '../lib/gemini';
import { cn } from '../lib/utils';
import { format } from 'date-fns';

interface AIPriceAnalysisViewProps {
  invoices: Invoice[];
  onClose: () => void;
}

export default function AIPriceAnalysisView({ invoices, onClose }: AIPriceAnalysisViewProps) {
  const [loading, setLoading] = useState(true);
  const [data, setData] = useState<AIPriceAnalysisResult | null>(null);

  useEffect(() => {
    function runAnalysis() {
      if (invoices.length === 0) {
        setLoading(false);
        return;
      }
      
      // Local Implementation of Price Evolution Calculation
      const productMap = new Map<string, { date: string; price: number; store: string }[]>();

      // Read from all invoices
      invoices.forEach(inv => {
        inv.items.forEach(item => {
          // Normalize name (very basic normalization)
          const normalizedName = item.name.trim();
          if (!productMap.has(normalizedName)) {
            productMap.set(normalizedName, []);
          }
          productMap.get(normalizedName)!.push({
            date: inv.date,
            price: item.price,
            store: inv.store
          });
        });
      });

      const processedProducts: ProcessedProduct[] = [];
      let totalChanges = 0;

      productMap.forEach((history, name) => {
        // 1. Sort history by date
        const sortedHistory = [...history].sort((a, b) => 
          new Date(a.date).getTime() - new Date(b.date).getTime()
        );

        // 2. Identify all price change points
        const changes: PriceChangeRecord[] = [];
        for (let i = 1; i < sortedHistory.length; i++) {
          const current = sortedHistory[i];
          const previous = sortedHistory[i - 1];

          if (Math.abs(current.price - previous.price) > 0.01) {
            changes.push({
              from: previous.price,
              to: current.price,
              date: current.date,
              diff: (current.price > previous.price ? '+' : '') + (current.price - previous.price).toFixed(2)
            });
            totalChanges++;
          }
        }

        // Only include products that appear more than once to show evolution or at least one
        processedProducts.push({
          name,
          full_history: sortedHistory,
          all_detected_changes: changes
        });
      });

      // Filter out products with no changes to keep the view clean, or sort by number of changes
      processedProducts.sort((a, b) => b.all_detected_changes.length - a.all_detected_changes.length);

      const result: AIPriceAnalysisResult = {
        summary: `נותחו ${processedProducts.length} מוצרים מתוך ${invoices.length} חשבוניות. זוהו סך הכל ${totalChanges} שינויי מחירים.`,
        processed_products: processedProducts.filter(p => invoices.length === 1 || p.full_history.length > 1) // only show products with history > 1 if multiple invoices
      };

      setData(result);
      setLoading(false);
    }
    
    // Slight delay to allow UI to render the loading state smoothly
    const timer = setTimeout(() => {
      runAnalysis();
    }, 100);
    
    return () => clearTimeout(timer);
  }, [invoices]);

  return (
    <div className="space-y-6" dir="rtl">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-3">
          <div className="w-12 h-12 bg-purple-100 text-purple-600 rounded-2xl flex items-center justify-center">
            <BrainCircuit className="w-6 h-6" />
          </div>
          <div>
            <h2 className="text-2xl font-black">ניתוח מחירים באמצעות AI</h2>
            <p className="text-sm text-gray-400">ניתוח מעמיק ומעקב אחר כל החשבוניות (לא מוגבל רק ל-2 האחרונות)</p>
          </div>
        </div>
        <button 
          onClick={onClose}
          className="text-xs font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 px-4 py-2 rounded-xl flex items-center gap-2 transition-colors"
        >
          <ChevronLeft className="w-4 h-4 ml-1" />
          <span>חזרה ללוח הבקרה</span>
        </button>
      </div>

      {loading ? (
        <div className="flex flex-col items-center justify-center py-20 bg-white rounded-3xl border border-gray-100">
          <Loader2 className="w-12 h-12 animate-spin text-purple-600 mb-4" />
          <p className="text-lg font-bold text-gray-700">מחשב מגמות מכל החשבוניות בהיסטוריה...</p>
          <p className="text-sm text-gray-400">זה עשוי לקחת מספר שניות</p>
        </div>
      ) : !data || data.processed_products.length === 0 ? (
        <div className="bg-white rounded-3xl p-8 text-center border border-gray-100 shadow-sm">
          <p className="text-gray-500 font-medium">לא נמצאו נתונים מספיקים לניתוח או שאירעה שגיאה (וודא שיש לך לפחות 2 חשבוניות ומפתח API תקין).</p>
        </div>
      ) : (
        <div className="space-y-6">
          <div className="bg-purple-50 text-purple-900 p-6 rounded-3xl border border-purple-100 shadow-sm">
            <h3 className="text-sm font-bold text-purple-500 mb-2 uppercase tracking-widest">תקציר AI</h3>
            <p className="text-lg font-medium">{data.summary}</p>
          </div>

          <div className="grid gap-6 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
            {data.processed_products.map((item, idx) => {
              const hasChanges = item.all_detected_changes.length > 0;
              
              return (
                <motion.div 
                  initial={{ opacity: 0, y: 20 }}
                  animate={{ opacity: 1, y: 0 }}
                  transition={{ delay: idx * 0.05 }}
                  key={idx}
                  className="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm flex flex-col hover:shadow-md transition-shadow"
                >
                  <div className="flex items-start justify-between mb-4">
                    <h3 className="font-bold text-gray-900 line-clamp-2 pl-2">{item.name}</h3>
                  </div>

                  {hasChanges ? (
                    <div className="space-y-3 mb-6">
                      <h4 className="text-xs font-bold text-orange-500 uppercase tracking-wider mb-2">שינויים שזוהו</h4>
                      {item.all_detected_changes.map((change, i) => {
                        const isInc = parseFloat(change.diff) > 0;
                        const Icon = isInc ? TrendingUp : TrendingDown;
                        return (
                          <div key={i} className={cn("p-3 rounded-xl border text-sm", isInc ? "bg-red-50 border-red-100" : "bg-emerald-50 border-emerald-100")}>
                            <div className="flex items-center justify-between mb-1">
                              <div className="flex items-center gap-2">
                                <span className={cn("font-bold line-through opacity-60", isInc ? "text-red-700" : "text-emerald-700")}>₪{change.from.toFixed(2)}</span>
                                <ArrowLeft className={cn("w-3 h-3", isInc ? "text-red-400" : "text-emerald-400")} />
                                <span className={cn("font-black", isInc ? "text-red-700" : "text-emerald-700")}>₪{change.to.toFixed(2)}</span>
                              </div>
                              <div className={cn("text-xs font-black px-2 py-0.5 rounded-md flex items-center gap-1", isInc ? "bg-red-100 text-red-700" : "bg-emerald-100 text-emerald-700")}>
                                <Icon className="w-3 h-3" />
                                <span dir="ltr">{change.diff}</span>
                              </div>
                            </div>
                            <div className={cn("text-[10px]", isInc ? "text-red-500" : "text-emerald-500")}>
                              {change.date ? format(new Date(change.date), 'dd/MM/yyyy') : 'N/A'}
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  ) : (
                    <p className="text-sm font-medium text-slate-500 mb-6 bg-slate-50 px-3 py-2 rounded-xl">
                      לא נצפו שינויים במחיר.
                    </p>
                  )}

                  <div className="mt-auto space-y-2 pt-4 border-t border-gray-50">
                    <h4 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">היסטוריית מחירים מלאה</h4>
                    {item.full_history.map((hist, i) => (
                      <div key={i} className="flex items-center justify-between text-sm py-1">
                        <div className="flex flex-col">
                          <span className="font-black text-gray-800">₪{hist.price.toFixed(2)}</span>
                          <span className="text-[10px] text-gray-500">{hist.store}</span>
                        </div>
                        <span className="text-[11px] font-medium text-slate-500 bg-slate-50 px-2 py-1 rounded-lg border border-slate-100">
                          {hist.date ? format(new Date(hist.date), 'dd/MM/yyyy') : 'N/A'}
                        </span>
                      </div>
                    ))}
                  </div>
                </motion.div>
              );
            })}
          </div>
        </div>
      )}
    </div>
  );
}
